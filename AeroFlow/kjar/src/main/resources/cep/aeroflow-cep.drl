package cep;

global com.aeroflow.service.services.DroolsEngineService logService;
global com.aeroflow.service.services.RebookingService rebookingService; // DODAJ OVO U DRL FAJL!

import com.aeroflow.model.*;
import com.aeroflow.model.events.*;
import com.aeroflow.model.enums.*;

declare FlightUpdateEvent
    @role( event )
    @timestamp( timestamp )
end

declare PassengerScanEvent
    @role( event )
    @timestamp( timestamp )
end

declare BaggageScanEvent
    @role( event )
    @timestamp( timestamp )
end

declare SecurityQueueEvent
    @role( event )
    @timestamp( timestamp )
end

declare GateChangedEvent
    @role( event )
    @timestamp( timestamp )
end

rule "DEBUG: Ispisi sve objekte"
when
    $o : Object()
then
    // logService.log("[DEBUG] Učitano u memoriju: " + $o.getClass().getSimpleName());
end

rule "CEP 1: Detekcija kriticnog kasnjenja i AUTOMATSKI REBOOKING"
when
    $event : FlightUpdateEvent($fn: flightNumber, status == FlightStatus.DELAYED, $newArrival: newEstimatedTime)
    $flight1 : Flight(flightNumber == $fn, $destAirport: destination, $scheduledArr: scheduledArrival)

    // Provjera kašnjenja > 30 min
    eval((java.sql.Timestamp.valueOf($newArrival).getTime() - java.sql.Timestamp.valueOf($scheduledArr).getTime()) > 1800000)

    $itinerary : Itinerary($passenger: passenger, $flights: flights)
    Flight(flightNumber == $fn) from $flights
    $flight2 : Flight($fn2: flightNumber, flightNumber != $fn, origin.code == $destAirport.code, $scheduledDep : scheduledDeparture) from $flights

    // Provjera MCT < 45 min
    eval((java.sql.Timestamp.valueOf($scheduledDep).getTime() - java.sql.Timestamp.valueOf($newArrival).getTime()) < 2700000)
then
    logService.log("\n[CEP PRAVILO 1] UPOZORENJE: Let " + $fn + " kasni preko 30 min. Presjedanje na let " + $fn2 + " je ugroženo za putnika: " + $passenger.getName());
    rebookingService.rebookPassenger($passenger);

    modify($passenger) {
        setCurrentStatus(PassengerStatus.REBOOKED)
    }
end

// ========================================================================
// PRAVILO 2: Detekcija kaskadnih kašnjenja i zagušenja aerodroma
// ========================================================================
rule "CEP 2: Kaskadna kasnjenja - Aktivacija zastitnog bafera"
when
    $brojKasnjenja : Number(intValue > 10) from accumulate (
        $e: FlightUpdateEvent(status == FlightStatus.DELAYED) over window:time(15m),
        count($e)
    )
    $sqEvent : SecurityQueueEvent(waitTimeIncrease > 200) over window:time(10m)
then
    logService.log("\n[CEP PRAVILO 2] KRIZA NA TERMINALU: Detektovano " + $brojKasnjenja + " kašnjenja i gužva na bezbjednosti! Sva MCT vremena se proaktivno povećavaju za 30 minuta.");
end

// ========================================================================
// PRAVILO 3: Proaktivna detekcija odvajanja prtljaga
// ========================================================================
rule "CEP 3: Proaktivna detekcija i preusmjeravanje prtljaga"
when
    $pScan : PassengerScanEvent($pid: passengerId, location == "GATE_DEPARTURE")
    $baggage : Baggage(owner != null, owner.getPassengerId() == $pid, $tag: baggageTag, $currentFlight: assignedFlight)
    not ( BaggageScanEvent(baggageTag == $tag, location == "TRANSFER_BELT") )

    // Pronađi sljedeći let za istu destinaciju
    $nextFlight : Flight(destination == $currentFlight.destination, scheduledDeparture > $currentFlight.scheduledDeparture)
then
    logService.log("\n[CEP PRAVILO 3] ALARM ZA PRTLJAG: Putnik " + $pid + " je stigao na gejt, ali kofer " + $tag + " nije prošao transfer traku na vrijeme.");
    modify($baggage) {
        setStatus(BaggageStatus.RE_ROUTED),
        setAssignedFlight($nextFlight)
    }
end

// ========================================================================
// PRAVILO 4: Ekonomska optimizacija zadržavanja leta
// ========================================================================
rule "CEP 4: Ekonomska isplativost zadrzavanja leta"
when
    $event : FlightUpdateEvent($fn: flightNumber, status == FlightStatus.DELAYED, $newArrival: newEstimatedTime)

    // JU501 je connecting, zakazan za now() + 5m
    $connectingFlight : Flight($cFn: flightNumber == "JU501", status == FlightStatus.SCHEDULED, $scheduledDep: scheduledDeparture)

    // Kasnjenje uzrokuje da novi dolazak bude NAKON polaska (Razlika veća od 0), ali manja od 15 min (900000 ms)
    eval((java.sql.Timestamp.valueOf($newArrival).getTime() - java.sql.Timestamp.valueOf($scheduledDep).getTime()) > 0 &&
         (java.sql.Timestamp.valueOf($newArrival).getTime() - java.sql.Timestamp.valueOf($scheduledDep).getTime()) <= 900000)

    // FIX: Sigurno prebrojavanje bez 'contains'
    $brojPutnika : Number(intValue > 15) from accumulate (
        $it : Itinerary($fl: flights) and
        Flight(flightNumber == $fn) from $fl and
        Flight(flightNumber == $cFn) from $fl,
        count($it)
    )
then
    logService.log("\n[CEP PRAVILO 4] SMART HOLD AKTIVIRAN: Zadržava se polazak leta " + $cFn + " jer dolazi grupa od " + $brojPutnika + " tranzitnih putnika iz leta " + $fn);
    modify($connectingFlight) {
        setStatus(FlightStatus.DELAYED)
    }
end

// ========================================================================
// PRAVILO 5: Kritična promjena gejta
// ========================================================================
rule "CEP 5: Hitno dispeciranje Transfer Cart vozila"
when
    $gateEvent : GateChangedEvent($fn: flightNumber, $ts: timestamp)
    $flight : Flight(flightNumber == $fn, $departure: scheduledDeparture)

    // Vrijeme do polaska je manje od 35 minuta (35m = 2100000 ms)
    eval((java.sql.Timestamp.valueOf($departure).getTime() - $ts.getTime()) < 2100000)

    // FIX: Pretraga bez 'contains'
    $itinerary : Itinerary($passenger: passenger, $fl: flights)
    exists Flight(flightNumber == $fn) from $fl
then
    logService.log("\n[CEP PRAVILO 5] LOGISTIKA UGROZENA: Let " + $fn + " je promijenio terminal! Automatski šaljem električno vozilo za putnika " + $passenger.getName());
end
package forward;

global com.aeroflow.service.services.DroolsEngineService logService;

import com.aeroflow.model.*;
import com.aeroflow.model.enums.*;
import com.aeroflow.service.services.DroolsEngineService;
import com.aeroflow.model.Fault;
import com.aeroflow.model.Disruption;
import com.aeroflow.model.Compensation;
import com.aeroflow.model.Flight;
import com.aeroflow.model.Itinerary;
import com.aeroflow.model.Passenger;

// ========================================================================
// NIVO 1: Klasifikacija statusa putnika
// ========================================================================
rule "Nivo 1: Detekcija ekstremnog kasnjenja i promjena statusa"
when
    $flight: Flight($fn: flightNumber, status == FlightStatus.DELAYED, actualArrival != null, scheduledArrival != null)

    // Kašnjenje > 60m (3600000 ms)
    eval((java.sql.Timestamp.valueOf($flight.getActualArrival()).getTime() - java.sql.Timestamp.valueOf($flight.getScheduledArrival()).getTime()) > 3600000)

    $itinerary: Itinerary($passenger: passenger, flights contains $flight)
    eval($passenger.getCurrentStatus() == PassengerStatus.SEVERELY_DELAYED || $passenger.getCurrentStatus() == PassengerStatus.REBOOKED)
then
    logService.log("[FORWARD NIVO 1] Putnik " + $passenger.getName() + " je u statusu " + $passenger.getCurrentStatus() + ". Pokrecem analizu kompenzacije.");

    if($passenger.getCurrentStatus() != PassengerStatus.SEVERELY_DELAYED) {
        modify($passenger) {
            setCurrentStatus(PassengerStatus.SEVERELY_DELAYED)
        }
    }
end

// ========================================================================
// NIVO 2: Procjena logističkog uticaja (Grananje)
// ========================================================================
rule "Nivo 2A: Dnevno cekanje (LONG_DAYTIME_LAYOVER)"
when
    $passenger: Passenger(currentStatus == PassengerStatus.SEVERELY_DELAYED)
    $itinerary: Itinerary(passenger == $passenger, $flights: flights)
    $nextFlight: Flight(status == FlightStatus.SCHEDULED, $depTime: scheduledDeparture) from $flights

    eval($depTime != null && $depTime.toLocalDate().equals(java.time.LocalDate.now()))
    eval((java.sql.Timestamp.valueOf($depTime).getTime() - System.currentTimeMillis()) > 21600000)
then
    logService.log("[FORWARD NIVO 2A] Dnevno čekanje duže od 6h za putnika: " + $passenger.getPassengerId());
    insert(new Disruption($passenger.getPassengerId(), "LONG_DAYTIME_LAYOVER"));
end

rule "Nivo 2B: Nocno cekanje (OVERNIGHT_STAY_REQUIRED)"
when
    $passenger: Passenger(currentStatus == PassengerStatus.SEVERELY_DELAYED)
    $itinerary: Itinerary(passenger == $passenger, $flights: flights)
    $nextFlight: Flight(status == FlightStatus.SCHEDULED, $depTime: scheduledDeparture) from $flights

    eval($depTime != null && $depTime.toLocalDate().isAfter(java.time.LocalDate.now()))
then
    logService.log("[FORWARD NIVO 2B] Potrebno noćenje za putnika: " + $passenger.getPassengerId());
    insert(new Disruption($passenger.getPassengerId(), "OVERNIGHT_STAY_REQUIRED"));
end

// ========================================================================
// NIVO 3: Odluka o nivou kompenzacije (SA SMS PORUKAMA)
// ========================================================================
rule "Nivo 3A: Dodjela Lounge pristupa i obroka"
when
    $disruption: Disruption(impact == "LONG_DAYTIME_LAYOVER", $pid: passengerId)
    Fault(party == "Airline_Fault")
    $passenger: Passenger(getPassengerId() == $pid)
then
    logService.log("[FORWARD NIVO 3A] Akcija: Generišem kompenzaciju LOUNGE_ACCESS_AND_MEALS za putnika: " + $pid);

    Compensation comp = new Compensation();
    comp.setType(CompensationType.LOUNGE_ACCESS_AND_MEALS);
    comp.setPassenger($passenger);
    // SMS poruka
    comp.setMessage("SMS: Poštovani " + $passenger.getName() + ", zbog kašnjenja ostvarili ste pravo na besplatan obrok i Lounge pristup na aerodromu.");
    insert(comp);
end

rule "Nivo 3B: Dodjela Hotela i prevoza"
when
    $disruption: Disruption(impact == "OVERNIGHT_STAY_REQUIRED", $pid: passengerId)
    Fault(party == "Airline_Fault")
    $passenger: Passenger(getPassengerId() == $pid)
then
    logService.log("[FORWARD NIVO 3B] Akcija: Generišem kompenzaciju HOTEL_AND_TRANSPORT za putnika: " + $pid);

    Compensation comp = new Compensation();
    comp.setType(CompensationType.HOTEL_AND_TRANSPORT);
    comp.setPassenger($passenger);
    // SMS poruka
    comp.setMessage("SMS: Poštovani " + $passenger.getName() + ", zbog neophodnog noćenja obezbijedili smo Vam hotel i organizovan taxi prevoz.");
    insert(comp);
end
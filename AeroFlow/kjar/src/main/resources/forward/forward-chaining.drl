package forward;

global com.aeroflow.service.services.DroolsEngineService logService;

import com.aeroflow.model.*;
import com.aeroflow.model.enums.*;
import java.time.temporal.ChronoUnit;
import com.aeroflow.service.services.DroolsEngineService;

// ========================================================================
// DEKLARACIJA INTERNIH ČINJENICA (Pomoćne klase za rezonovanje)
// ========================================================================
declare Disruption
    passengerId: String
    impact: String
end

declare Fault
    flightNumber: String
    party: String
end

// ========================================================================
// NIVO 1: Klasifikacija statusa putnika
// ========================================================================
rule "Nivo 1: Detekcija ekstremnog kasnjenja i promjena statusa"
when
    // Let kasni i znamo njegovo planirano i stvarno vrijeme dolaska
    $flight: Flight($fn: flightNumber, status == FlightStatus.DELAYED, actualArrival != null, scheduledArrival != null)

    // Kašnjenje je strogo veće od 60 minuta
    eval(ChronoUnit.MINUTES.between($flight.getScheduledArrival(), $flight.getActualArrival()) > 60)

    // Putnik se nalazi na tom letu
    $itinerary: Itinerary($passenger: passenger, flights contains $flight)
then
    logService.log("\n[FORWARD NIVO 1] Let " + $fn + " kasni > 60m. Mijenjam status putnika " + $passenger.getName() + " u SEVERELY_DELAYED.");

    // MODIFY okida ponovnu evaluaciju pravila (okida Nivo 2)
    modify($passenger) {
        setCurrentStatus(PassengerStatus.SEVERELY_DELAYED)
    }
end

// ========================================================================
// NIVO 2: Procjena logističkog uticaja (Grananje)
// ========================================================================
rule "Nivo 2A: Dnevno cekanje (LONG_DAYTIME_LAYOVER)"
when
    // Pravilo se aktivira tek kada Nivo 1 postavi ovaj status
    $passenger: Passenger(currentStatus == PassengerStatus.SEVERELY_DELAYED, $pid: passengerId)
    $itinerary: Itinerary(passenger == $passenger, $flights: flights)

    // Pronalazak sljedećeg leta
    $nextFlight: Flight(status == FlightStatus.SCHEDULED, $depTime: scheduledDeparture) from $flights

    // Simulacija uslova: Čekanje je veće od 6 sati, ali let je ISTOG dana
    eval($depTime != null && $depTime.toLocalDate().equals(java.time.LocalDate.now()))
    eval(ChronoUnit.HOURS.between(java.time.LocalDateTime.now(), $depTime) > 6)
then
    logService.log("[FORWARD NIVO 2A] Dnevno čekanje duže od 6h za putnika: " + $pid);

    // INSERT okida Nivo 3
    insert(new Disruption($pid, "LONG_DAYTIME_LAYOVER"));
end

rule "Nivo 2B: Nocno cekanje (OVERNIGHT_STAY_REQUIRED)"
when
    $passenger: Passenger(currentStatus == PassengerStatus.SEVERELY_DELAYED, $pid: passengerId)
    $itinerary: Itinerary(passenger == $passenger, $flights: flights)

    $nextFlight: Flight(status == FlightStatus.SCHEDULED, $depTime: scheduledDeparture) from $flights

    // Uslov: Let je sljedećeg kalendarskog dana
    eval($depTime != null && $depTime.toLocalDate().isAfter(java.time.LocalDate.now()))
then
    logService.log("[FORWARD NIVO 2B] Potrebno noćenje za putnika: " + $pid);

    // INSERT okida Nivo 3
    insert(new Disruption($pid, "OVERNIGHT_STAY_REQUIRED"));
end

// ========================================================================
// NIVO 3: Odluka o nivou kompenzacije
// ========================================================================
rule "Nivo 3A: Dodjela Lounge pristupa i obroka"
when
    // Pravilo čeka činjenicu iz Nivoa 2A
    $disruption: Disruption(impact == "LONG_DAYTIME_LAYOVER", $pid: passengerId)

    // Provjera da li je krivica do kompanije
    Fault(party == "Airline_Fault")

    $passenger: Passenger(passengerId == $pid)
    $itinerary: Itinerary(passenger == $passenger)
then
    logService.log("[FORWARD NIVO 3A] Akcija: Generišem kompenzaciju LOUNGE_ACCESS_AND_MEALS za putnika: " + $pid);

    Compensation comp = new Compensation();
    comp.setType(CompensationType.LOUNGE_ACCESS_AND_MEALS);
    insert(comp); // Sistem sada može preko API-ja preuzeti ovu kompenzaciju i poslati QR kod
end

rule "Nivo 3B: Dodjela Hotela i prevoza"
when
    // Pravilo čeka činjenicu iz Nivoa 2B
    $disruption: Disruption(impact == "OVERNIGHT_STAY_REQUIRED", $pid: passengerId)

    Fault(party == "Airline_Fault")

    $passenger: Passenger(passengerId == $pid)
then
    logService.log("[FORWARD NIVO 3B] Akcija: Generišem kompenzaciju HOTEL_AND_TRANSPORT za putnika: " + $pid);

    Compensation comp = new Compensation();
    comp.setType(CompensationType.HOTEL_AND_TRANSPORT);
    insert(comp); // Sistem preuzima ovo i rezerviše sobu
end